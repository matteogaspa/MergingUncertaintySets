alpha <- 0.1 # conf. level
res <- rep(NA, B)
quant <- qbinom(p = alpha, k, 1-alpha) # inf(x:F(x)>=alpha)
for(i in 1:B){
xs <- rnorm(n*k)
mat_ints <- matrix(NA, nrow = k, ncol = 2)
for(j in 1:k){
subs <- ((j-1)*n + 1):((j-1)*n + n)
mat_ints[j,] <- c(mean(xs[subs]) - qnorm(1-alpha/2)*sqrt(1/n), mean(xs[subs]) + qnorm(1-alpha/2)*sqrt(1/n))
}
out <- apply(mat_ints, 1, function(x) c(x[1] <= 0 & 0 <= x[2]))
res[i] <- sum(out) >= quant
}
mean(res); 1-pbinom(quant-1,k,1-alpha)
set.seed(123)
for(i in 1:B){
xs <- rnorm(n*k)
mat_ints <- matrix(NA, nrow = k, ncol = 2)
for(j in 1:k){
subs <- ((j-1)*n + 1):((j-1)*n + n)
mat_ints[j,] <- c(mean(xs[subs]) - qnorm(1-alpha/2)*sqrt(1/n), mean(xs[subs]) + qnorm(1-alpha/2)*sqrt(1/n))
}
out <- apply(mat_ints, 1, function(x) c(x[1] <= 0 & 0 <= x[2]))
res[i] <- sum(out) >= quant
}
mean(res); 1-pbinom(quant-1,k,1-alpha)
rm(list = ls())
library(conformalInference)
library(dplyr)
library(ggplot2)
beta <- 2
funs <- lasso.funs(standardize = F, intercept = F, lambda = 1)
B   <- 5000         # number of replications
res <- rep(NA, B)
alpha <- 0.1
B   <- 10000         # number of replications
res <- rep(NA, B)
alpha <- 0.1
k <- 21
n <- 100
n0 <- 1
qq_bin <- qbinom(alpha, k, 1-alpha)
set.seed(123)
for(i in 1:B){
vote <- rep(NA, k)
X0 <- rnorm(n0)
y0 <- X0 * beta + rnorm(n0)
for(j in 1:k){
X <- rnorm(n)
y <- X * beta + rnorm(n)
cis <- conformal.pred(cbind(rep(1,n), X), y, X0, alpha = alpha, train.fun = funs$train, predict.fun = funs$predict)
vote[j] <- I(cis$lo <= y0 & y0 <= cis$up)
}
res[i] <- ifelse(sum(vote) > 15, 1, 0)
if(i%%100==0) cat(i, "\n")
}
