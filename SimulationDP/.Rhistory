samp_plus  <- samp[rnd_obs]
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov_c[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l_c[i,j]   <- cis[2]-cis[1]
}
# majority vote
cov_c[i, 11] <- I(mean(cov_c[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l_c[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov_c[i, 12] <- I(mean(cov_c[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l_c[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov_c[i, 13] <- I(mean(cov_c[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l_c[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int)
cov_c[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l_c[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
l_c[is.na(l_c)]     <- 0 #empty set
cov_c[is.na(cov_c)] <- 0 #empty set
colMeans(cov_c); colMeans(l_c)
cov_ma <- list(cov90=cov90,cov75=cov75,cov50=cov50,
l90=l90, l75=l75, l50=l50, cov_c=cov_c, l_c=l_c)
save(cov_ma, file = "cov_ma.RData")
# agent
results <- matrix(NA, 8, 6)
results[1,1] <- lng[1,1]
results[2,1] <- colMeans(cov)[1:k]%>%mean
results[3,1] <- cov_ma$l90[1,1]
results[4,1] <- colMeans(cov90)[1:k]%>%mean
