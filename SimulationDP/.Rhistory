# Functions ----
nppr_algorithm <- function(x_t, r_t=1, g_t=1){
x_t_ceil <- ceiling((x_t*g_t)/g_t)
x_t_floor <- floor((x_t*g_t)/g_t)
if(x_t_ceil==x_t_floor){
y_t <- x_t
}else{
y_t <- sample(c(x_t_ceil, x_t_floor), 1, prob = c(g_t*(x_t-x_t_floor), g_t*(x_t_ceil-x_t)))
}
u_t <- sample(seq(0,g_t,by=1)/g_t, 1)
z_t <- sample(c(y_t, u_t), 1, prob=c(r_t, 1-r_t))
return(z_t)
}
nppr_algorithm <- Vectorize(nppr_algorithm, "x_t")
nppr_adj_mean <- function(z_t, r_t){
z_t_adj <- z_t - 0.5*(1-r_t)
return(mean(z_t_adj)/mean(r_t))
}
nppr_ci <- function(z_t, r_t, alpha = 0.05){
mu_star <- nppr_adj_mean(z_t, r_t)
n   <- length(z_t)
a_t <- alpha/2
q_t <- sqrt(log(1/a_t)/(2*n*(mean(r_t)^2)))
return(c(mu_star-q_t, mu_star+q_t))
}
set.seed(1234)
# Simulations -----
B <- 5000
n <- 10
cov <- rep(NA,B)
cis <- matrix(NA, nrow = B, ncol = 2)
for(i in 1:B){
samp <- runif(n)
samp_nppr <- nppr_algorithm(samp)
cis[i,] <- nppr_ci(samp_nppr, .5, 0.05)
cov[i] <- I(cis[i,1] <= 0.5 & 0.5 <= cis[i,2])
}
mean(cov)
# Simulations with multiple agents 2 -----
B <- 10000
n <- 100
k <- 10
alpha <- 0.1
r_t <- (exp(2)-1)/(exp(2)+1)
# Agent k share 50% of the data with agent k-1
cov50 <- l50 <- matrix(0, nrow = B, ncol = 14)
for(i in 1:B){
# first agent
samp       <- runif(n)
cis        <- nppr_ci(nppr_algorithm(samp), r_t, alpha)
cov50[i,1] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l50[i,1]   <- cis[2]-cis[1]
M_int      <- matrix(NA, k, 2)
M_int[1,]  <- cis
# other k-1 agents
for(j in 2:k){
rnd_obs    <- sample(1:n, n/2, replace = F)
samp_plus  <- c(samp[rnd_obs], runif(n/2))
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov50[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l50[i,j]   <- cis[2]-cis[1]
samp       <- samp_plus
}
# majority vote
cov50[i, 11] <- I(mean(cov50[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l50[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov50[i, 12] <- I(mean(cov50[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l50[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov50[i, 13] <- I(mean(cov50[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l50[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int[sample(1:k,k)])
cov50[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l50[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
rm(list=ls())
source("utils.R")
# Functions ----
nppr_algorithm <- function(x_t, r_t=1, g_t=1){
x_t_ceil <- ceiling((x_t*g_t)/g_t)
x_t_floor <- floor((x_t*g_t)/g_t)
if(x_t_ceil==x_t_floor){
y_t <- x_t
}else{
y_t <- sample(c(x_t_ceil, x_t_floor), 1, prob = c(g_t*(x_t-x_t_floor), g_t*(x_t_ceil-x_t)))
}
u_t <- sample(seq(0,g_t,by=1)/g_t, 1)
z_t <- sample(c(y_t, u_t), 1, prob=c(r_t, 1-r_t))
return(z_t)
}
nppr_algorithm <- Vectorize(nppr_algorithm, "x_t")
nppr_adj_mean <- function(z_t, r_t){
z_t_adj <- z_t - 0.5*(1-r_t)
return(mean(z_t_adj)/mean(r_t))
}
nppr_ci <- function(z_t, r_t, alpha = 0.05){
mu_star <- nppr_adj_mean(z_t, r_t)
n   <- length(z_t)
a_t <- alpha/2
q_t <- sqrt(log(1/a_t)/(2*n*(mean(r_t)^2)))
return(c(mu_star-q_t, mu_star+q_t))
}
set.seed(1234)
# Simulations -----
B <- 5000
n <- 10
cov <- rep(NA,B)
cis <- matrix(NA, nrow = B, ncol = 2)
for(i in 1:B){
samp <- runif(n)
samp_nppr <- nppr_algorithm(samp)
cis[i,] <- nppr_ci(samp_nppr, .5, 0.05)
cov[i] <- I(cis[i,1] <= 0.5 & 0.5 <= cis[i,2])
}
mean(cov)
# Simulations with multiple agents 2 -----
B <- 10000
n <- 100
k <- 10
alpha <- 0.1
r_t <- (exp(2)-1)/(exp(2)+1)
# Agent k share 50% of the data with agent k-1
cov50 <- l50 <- matrix(0, nrow = B, ncol = 14)
for(i in 1:B){
# first agent
samp       <- runif(n)
cis        <- nppr_ci(nppr_algorithm(samp), r_t, alpha)
cov50[i,1] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l50[i,1]   <- cis[2]-cis[1]
M_int      <- matrix(NA, k, 2)
M_int[1,]  <- cis
# other k-1 agents
for(j in 2:k){
rnd_obs    <- sample(1:n, n/2, replace = F)
samp_plus  <- c(samp[rnd_obs], runif(n/2))
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov50[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l50[i,j]   <- cis[2]-cis[1]
samp       <- samp_plus
}
# majority vote
cov50[i, 11] <- I(mean(cov50[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l50[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov50[i, 12] <- I(mean(cov50[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l50[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov50[i, 13] <- I(mean(cov50[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l50[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int[sample(1:k,k),])
cov50[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l50[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
l50[is.na(l50)]     <- 0 #empty set
cov50[is.na(cov50)] <- 0 #empty set
colMeans(cov50); colMeans(l50)
# Agent k share 75% of the data with agent k-1
cov75 <- l75 <- matrix(0, nrow = B, ncol = 14)
for(i in 1:B){
# first agent
samp       <- runif(n)
cis        <- nppr_ci(nppr_algorithm(samp), r_t, alpha)
cov75[i,1] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l75[i,1]   <- cis[2]-cis[1]
M_int      <- matrix(NA, k, 2)
M_int[1,]  <- cis
# other k-1 agents
for(j in 2:k){
rnd_obs    <- sample(1:n, 0.75*n, replace = F)
samp_plus  <- c(samp[rnd_obs], runif(0.25*n))
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov75[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l75[i,j]   <- cis[2]-cis[1]
samp       <- samp_plus
}
# majority vote
cov75[i, 11] <- I(mean(cov75[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l75[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov75[i, 12] <- I(mean(cov75[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l75[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov75[i, 13] <- I(mean(cov75[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l75[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int[sample(1:k,k),])
cov75[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l75[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
l75[is.na(l75)]     <- 0 #empty set
cov75[is.na(cov75)] <- 0 #empty set
colMeans(cov75); colMeans(l75)
# Agent k share 90% of the data with agent k-1
cov90 <- l90 <- matrix(0, nrow = B, ncol = 14)
for(i in 1:B){
# first agent
samp       <- runif(n)
cis        <- nppr_ci(nppr_algorithm(samp), r_t, alpha)
cov90[i,1] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l90[i,1]   <- cis[2]-cis[1]
M_int      <- matrix(NA, k, 2)
M_int[1,]  <- cis
# other k-1 agents
for(j in 2:k){
rnd_obs    <- sample(1:n, 0.9*n, replace = F)
samp_plus  <- c(samp[rnd_obs], runif(0.1*n))
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov90[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l90[i,j]   <- cis[2]-cis[1]
samp       <- samp_plus
}
# majority vote
cov90[i, 11] <- I(mean(cov90[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l90[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov90[i, 12] <- I(mean(cov90[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l90[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov90[i, 13] <- I(mean(cov90[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l90[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int[sample(1:k,k),])
cov90[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l90[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
l90[is.na(l90)]     <- 0 #empty set
cov90[is.na(cov90)] <- 0 #empty set
colMeans(cov90); colMeans(l90)
## Draw from a common set -----
B <- 10000
n <- 100
k <- 10
alpha <- 0.1
r_t <- (exp(2)-1)/(exp(2)+1)
cov_c <- l_c <- matrix(0, nrow = B, ncol = 14)
for(i in 1:B){
# first agent
samp       <- runif(n*k/2)
M_int      <- matrix(NA, k, 2)
for(j in 1:k){
rnd_obs    <- sample(1:length(samp), n, replace = F)
samp_plus  <- samp[rnd_obs]
cis        <- nppr_ci(nppr_algorithm(samp_plus), r_t, alpha)
M_int[j,]  <- cis
cov_c[i,j] <- I(cis[1] < 0.5 & 0.5 < cis[2])
l_c[i,j]   <- cis[2]-cis[1]
}
# majority vote
cov_c[i, 11] <- I(mean(cov_c[i,1:k])>0.5)
ci_mv        <- majority_vote(M_int, rep(1,k))
l_c[i,11]    <- ci_mv[2]-ci_mv[1]
# rand MV
us           <- runif(1, 0.5, 1)
cov_c[i, 12] <- I(mean(cov_c[i,1:10])>us)
ci_rmv       <- majority_vote(M_int, rep(1,k), us)
l_c[i,12]    <- ci_rmv[2]-ci_rmv[1]
# rand U MV
us2          <- runif(1, 0, 1)
cov_c[i, 13] <- I(mean(cov_c[i,1:10])>us2)
ci_umv       <- majority_vote(M_int, rep(1,k), us2)
l_c[i,13]    <- ci_umv[2]-ci_umv[1]
# exch MV
ci_emv       <- exch_majority_vote(M_int[sample(1:k,k),])
cov_c[i,14]  <- I(ci_emv[1] < 0.5 & 0.5 < ci_emv[2])
l_c[i,14]    <- ci_emv[2]-ci_emv[1]
if(i %% 100 == 0) cat("iter:", i, "\n")
}
l_c[is.na(l_c)]     <- 0 #empty set
cov_c[is.na(cov_c)] <- 0 #empty set
colMeans(cov_c); colMeans(l_c)
cov_ma <- list(cov90=cov90,cov75=cov75,cov50=cov50,
l90=l90, l75=l75, l50=l50, cov_c=cov_c, l_c=l_c)
save(cov_ma, file = "cov_ma.RData")
# results -----
library(xtable)
library(dplyr)
# agent
results <- matrix(NA, 8, 5)
results[1,1] <- l_c[1,1]
results[2,1] <- colMeans(cov_c)[1:k]%>%mean
results[3,1] <- cov_ma$l90[1,1]
results[4,1] <- colMeans(cov90)[1:k]%>%mean
results[5,1] <- cov_ma$l75[1,1]
results[6,1] <- colMeans(cov75)[1:k]%>%mean
results[7,1] <- cov_ma$l50[1,1]
results[8,1] <- colMeans(cov50)[1:k]%>%mean
# majority vote
results[1,2] <- colMeans(l_c)[k+1]
results[2,2] <- colMeans(cov_c)[k+1]
results[3,2] <- colMeans(cov_ma$l50)[k+1]
results[4,2] <- colMeans(cov90)[k+1]
results[5,2] <- colMeans(cov_ma$l75)[k+1]
results[6,2] <- colMeans(cov75)[k+1]
results[7,2] <- colMeans(cov_ma$l90)[k+1]
results[8,2] <- colMeans(cov50)[k+1]
# rnd majority vote
results[1,3] <- colMeans(l_c)[k+2]
results[2,3] <- colMeans(cov_c)[k+2]
results[3,3] <- colMeans(cov_ma$l50, na.rm = T)[k+2]
results[4,3] <- colMeans(cov90)[k+2]
results[5,3] <- colMeans(cov_ma$l75, na.rm = T)[k+2]
results[6,3] <- colMeans(cov75)[k+2]
results[7,3] <- colMeans(cov_ma$l90, na.rm=T)[k+2]
results[8,3] <- colMeans(cov50)[k+2]
# randomized union
results[1,4] <- colMeans(l_c)[k+3]
results[2,4] <- colMeans(cov_c)[k+3]
results[3,4] <- colMeans(cov_ma$l50)[k+3]
results[4,4] <- colMeans(cov50)[k+3]
results[5,4] <- colMeans(cov_ma$l75)[k+3]
results[6,4] <- colMeans(cov75)[k+3]
results[7,4] <- colMeans(cov_ma$l90)[k+3]
results[8,4] <- colMeans(cov90)[k+3]
# exchangeable
results[1,5] <- colMeans(l_c)[k+4]
results[2,5] <- colMeans(cov_c)[k+4]
results[3,5] <- colMeans(cov_ma$l50)[k+4]
results[4,5] <- colMeans(cov90)[k+4]
results[5,5] <- colMeans(cov_ma$l75)[k+4]
results[6,5] <- colMeans(cov75)[k+4]
results[7,5] <- colMeans(cov_ma$l90)[k+4]
results[8,5] <- colMeans(cov50)[k+4]
colnames(results) <- c("Ck", "CM", "CR", "CU", "CE")
results <- as.data.frame(results)
print(xtable(results, digits = 3), include.rownames=F)
